<% if p("enabled") %>
<% if p("use_bpm") %>
check process loggr-system-metrics-agent
  with pidfile /var/vcap/sys/run/bpm/loggr-system-metrics-agent/loggr-system-metrics-agent.pid
  start program "/var/vcap/jobs/bpm/bin/bpm start loggr-system-metrics-agent"
  stop program "/var/vcap/jobs/bpm/bin/bpm stop loggr-system-metrics-agent"
  group vcap
<% else %>
check process system-metrics-agent
  with pidfile /var/vcap/sys/run/system-metrics-agent/system-metrics-agent.pid
  start program "/var/vcap/jobs/loggr-system-metrics-agent/bin/ctl start"
  stop program "/var/vcap/jobs/loggr-system-metrics-agent/bin/ctl stop"
  group vcap
<% end %>
<% end %>
